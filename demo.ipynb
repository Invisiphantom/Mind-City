    "import math\n",
    "from decimal import Decimal\n",
    "\n",
    "\n",
    "def f1(x):\n",
    "    return math.log(math.log(x))\n",
    "\n",
    "\n",
    "def f2(x):\n",
    "    return math.sqrt(math.log2(x))"
   ]
  },
