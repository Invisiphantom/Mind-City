    "import math\n",
    "import numpy as np\n",
    "\n",
    "# range(22,23,0.01)\n",
    "ran = np.arange(22,23,0.01)\n",
    "\n",
    "for n in ran:\n",
    "    print(f\"{n}\")\n",
    "    print(f\"{(2000-100*n)/math.sqrt(900 * n)}\")\n"
