   "source": [
    "import math\n",
    "from decimal import Decimal\n",
    "\n",
    "\n",
    "def f1(x):\n",
    "    return x * math.log2(x)\n",
    "\n",
    "\n",
    "def f2(x):\n",
    "    return 2 ** (math.sqrt(2 * math.log2(x)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1.0E+4, 22\n"
     ]
    }
   ],
   "source": [
    "n = 1000\n",
    "print(f\"{Decimal(f1(n)):.2}, {Decimal(f2(n)):.2}\")"
   ]
  }
